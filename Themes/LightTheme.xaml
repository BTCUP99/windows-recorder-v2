<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 亮色主题资源 -->
    <SolidColorBrush x:Key="WindowBackground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="PanelBackground" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="TextPrimary" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#666666"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#0078D4"/>
    <SolidColorBrush x:Key="AccentHover" Color="#106EBE"/>
    <SolidColorBrush x:Key="RecordButtonBrush" Color="#E81123"/>
    <SolidColorBrush x:Key="RecordButtonHover" Color="#C50F1F"/>
    <SolidColorBrush x:Key="PauseButtonBrush" Color="#FF8C00"/>
    <SolidColorBrush x:Key="GreenBrush" Color="#107C10"/>

</ResourceDictionary>