<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 暗色主题资源 -->
    <SolidColorBrush x:Key="WindowBackground" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="PanelBackground" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#404040"/>
    <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#AAAAAA"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#0078D4"/>
    <SolidColorBrush x:Key="AccentHover" Color="#1A8FFF"/>
    <SolidColorBrush x:Key="RecordButtonBrush" Color="#E81123"/>
    <SolidColorBrush x:Key="RecordButtonHover" Color="#FF3B4C"/>
    <SolidColorBrush x:Key="PauseButtonBrush" Color="#FF8C00"/>
    <SolidColorBrush x:Key="GreenBrush" Color="#6CCB5F"/>

</ResourceDictionary>