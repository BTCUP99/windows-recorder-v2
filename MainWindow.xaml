<Window x:Class="windows_recorder_v2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Windows 录音器 v2" Height="500" Width="600"
        WindowStartupLocation="CenterScreen"
        MinHeight="450" MinWidth="500">
    <Grid x:Name="MainGrid" Background="{DynamicResource WindowBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="{DynamicResource PanelBackground}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="15,10">
            <Grid>
                <TextBlock Text="Windows 录音器 v2"
                           FontSize="20" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimary}"
                           HorizontalAlignment="Left" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <ToggleButton x:Name="ThemeToggle"
                                  Width="40" Height="24"
                                  Click="ThemeToggle_Click"
                                  Cursor="Hand"
                                  ToolTip="切换主题">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="ToggleButton">
                                <Border x:Name="border" CornerRadius="12"
                                        Background="{DynamicResource BorderBrush}"
                                        Width="40" Height="24">
                                    <Ellipse x:Name="knob" Width="20" Height="20"
                                             Fill="White" HorizontalAlignment="Left" Margin="2,0,0,0"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#0078D4"/>
                                        <Setter TargetName="knob" Property="HorizontalAlignment" Value="Right"/>
                                        <Setter TargetName="knob" Property="Margin" Value="0,0,2,0"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </ToggleButton.Template>
                    </ToggleButton>
                    <TextBlock x:Name="ThemeLabel" Text="亮色" Margin="8,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondary}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 音频源选择 -->
        <Border Grid.Row="1" Background="{DynamicResource PanelBackground}"
                Margin="15,15,15,0" Padding="15" CornerRadius="8"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="音频源" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal">
                    <CheckBox x:Name="SystemAudioCheck" Content="系统声音" IsChecked="True"
                              Foreground="{DynamicResource TextPrimary}" Margin="0,0,20,0"
                              FontSize="13"/>
                    <CheckBox x:Name="MicrophoneCheck" Content="麦克风" IsChecked="True"
                              Foreground="{DynamicResource TextPrimary}" FontSize="13"/>
                </StackPanel>

                <TextBlock Text="输出格式" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}" Margin="0,15,0,10"/>
                <StackPanel Orientation="Horizontal">
                    <RadioButton x:Name="WavFormat" Content="WAV (无损)" GroupName="Format"
                                 IsChecked="True" Foreground="{DynamicResource TextPrimary}"
                                 FontSize="13" Margin="0,0,15,0"/>
                    <RadioButton x:Name="Mp3Format" Content="MP3 (压缩)" GroupName="Format"
                                 Foreground="{DynamicResource TextPrimary}" FontSize="13"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 录音状态显示 -->
        <Border Grid.Row="2" Background="{DynamicResource PanelBackground}"
                Margin="15,15,15,0" Padding="30" CornerRadius="8"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 音量指示器 -->
                <Grid Grid.Row="0">
                    <ProgressBar x:Name="VolumeBar" Height="8" Minimum="0" Maximum="100"
                                 Value="0" VerticalAlignment="Center"/>
                </Grid>

                <!-- 时间显示 -->
                <StackPanel Grid.Row="1" HorizontalAlignment="Center">
                    <TextBlock x:Name="TimeDisplay" Text="00:00:00"
                               FontSize="48" FontWeight="Light"
                               Foreground="{DynamicResource TextPrimary}"
                               HorizontalAlignment="Center" FontFamily="Consolas"/>
                    <TextBlock x:Name="StatusText" Text="准备就绪"
                               FontSize="14"
                               Foreground="{DynamicResource TextSecondary}"
                               HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>

                <!-- 录音按钮 -->
                <StackPanel Grid.Row="2" Orientation="Horizontal"
                            HorizontalAlignment="Center" Margin="0,20,0,0">
                    <Button x:Name="RecordButton" Width="100" Height="45"
                            Click="RecordButton_Click"
                            Cursor="Hand"
                            ToolTip="开始/停止录音">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" CornerRadius="22.5"
                                        Background="{DynamicResource RecordButtonBrush}">
                                    <TextBlock x:Name="btnText" Text="开始录音"
                                               Foreground="White" FontSize="14"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background"
                                                Value="{DynamicResource RecordButtonHover}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="PauseButton" Width="80" Height="45"
                            Margin="15,0,0,0"
                            Click="PauseButton_Click"
                            IsEnabled="False"
                            Cursor="Hand"
                            ToolTip="暂停/继续">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" CornerRadius="22.5"
                                        Background="{DynamicResource PauseButtonBrush}">
                                    <TextBlock x:Name="btnText" Text="暂停"
                                               Foreground="White" FontSize="14"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#FF7000"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 底部状态栏 -->
        <Border Grid.Row="3" Background="{DynamicResource PanelBackground}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="15,8">
            <Grid>
                <TextBlock x:Name="OutputPathText" Text="保存位置: 我的文档/WindowsRecorder"
                           FontSize="12"
                           Foreground="{DynamicResource TextSecondary}"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="VersionText" Text="v1.0.0"
                           FontSize="12"
                           Foreground="{DynamicResource TextSecondary}"
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>